COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")

REQUIRED_PREFIXES="fix|feature|docs|test|chore|improve|version|changelog|refactor"

# Si empieza por Merge -> válido
if [[ "$FIRST_LINE" =~ ^Merge ]]; then
    exit 0
fi

# Regex: opcional [ci skip], luego [prefijo obligatorio], luego espacio y mensaje no vacío
if [[ "$FIRST_LINE" =~ ^(\[ci skip\])?\[($REQUIRED_PREFIXES)\]\ .+ ]]; then
    exit 0
else
    echo "Invalid commit message"
    echo "Rules:"
    echo " - Optional [ci skip] at the beginning"
    echo " - Mandatory prefix: [fix], [feature], [docs], [test], [chore], [improve], [version], [changelog], [refactor]"
    echo " - A space and a non-empty message after the mandatory prefix"
    echo " - Commits starting with 'Merge' are valid"
    exit 1
fi